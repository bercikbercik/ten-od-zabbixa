          "datasource": {
            "type": "yesoreyeram-infinity-datasource",
            "uid": "${DS_ZABBIX-API-7-0}"
          },
          "filters": [],
          "format": "table",
          "global_query_id": "",
          "parser": "uql",
          "refId": "A",
          "root_selector": "$map(\n  $filter(result, function($h){\n    $count($filter($h.items ? $h.items : [], function($it){\n      $it.type = \"7\" and $it.status = \"0\"\n    })) > 0\n  }),\n  function($h){\n    {\n      \"host\": $h.host,\n      \"active\": $h.active_available,\n      \"last_data\": (\n        $vals := $filter($h.items ? $h.items : [], function($it){\n          $it.type = \"7\" and $it.status = \"0\"\n        }).lastclock;\n        $nums := $map($vals, function($v){ $number($v) });\n        $maxv := $max($nums);\n        $maxv > 0 ? $maxv * 1000 : null\n      )\n    }\n  }\n)",
          "source": "url",
          "type": "json",
          "uql": "parse-json\r\n| scope \"result\"\r\n| mv-expand \"interfaces\"\r\n| extend \"error_time\"=mul(\"interfaces.errors_from\",1000)\r\n| where \"interfaces.available\"!='1'\r\n| project \"host\"=\"host\", \"typ\"=\"interfaces.type\", \"błąd\"=\"interfaces.error\", \"czas błędu\"=\"error_time\", \"dostępność\"=\"interfaces.available\"",
          "url": "",
          "url_options": {
            "body_content_type": "application/json",
            "body_type": "raw",
            "data": "{\r\n  \"jsonrpc\": \"2.0\",\r\n  \"method\": \"host.get\",\r\n  \"params\": {\r\n    \"groupids\": 2,\r\n    \"output\": [\"hostid\",\"host\"],\r\n    \"selectInterfaces\": [\"interfaceid\",\"available\",\"type\",\"error\",\"errors_from\"],\r\n    \"filter\": { \"status\": 0 }\r\n  },\r\n  \"id\": 1\r\n}",
            "headers": [],
            "method": "POST"
          }
        }
